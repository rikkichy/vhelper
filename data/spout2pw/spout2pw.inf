[Version]
Signature="$CHICAGO$"

[DefaultInstall]
WineFakeDlls = Spout2PwFakeDlls

[DefaultInstall.Services]
AddService = Spout2Pw,0,Spout2PwService

[Spout2PwFakeDlls]
11,,spout2pw.exe,*
11,,spoutdxtoc.dll,*

[Spout2PwService]
Description="Spout to PipeWire bridge"
DisplayName="Spout2Pw"
ServiceBinary="%11%\spout2pw.exe"
ServiceType=288
StartType=2
ErrorControl=1
